  {
    "proposal_id": "c38a5cc4-aa53-415e-bea7-39b86b563e1a",
    "pattern_tags": [
      "multi_domain_convergence"
    ],
    "pattern_count": 3,
    "pattern_finding_type": "novel_pattern",
    "rule_type": "hard_rule",
    "rule_name": "multi_domain_convergence_block",
    "description": "Block transactions exhibiting multi-domain convergence patterns.",
    "proposed_change": {
      "condition": "transaction.domain in suspicious_domains and transaction.ip in known_fraud_ips",
      "verdict": "block",
      "rationale": "Multi-domain convergence patterns indicate potential coordinated fraud activities."
    },
    "expected_impact": "This rule will block transactions that are part of coordinated fraud attempts across multiple domains.",
    "risk": "There is a risk of blocking legitimate transactions if they match the convergence pattern by coincidence.",
    "status": "pending",
    "created_at": "2026-03-20T23:50:00.757360+00:00"
  },
  {
    "proposal_id": "f51f005b-a912-4109-a326-85f05e11b5f0",
    "pattern_tags": [
      "identity_fraud",
      "ring_fraud"
    ],
    "pattern_count": 3,
    "pattern_finding_type": "novel_pattern",
    "rule_type": "hard_rule",
    "rule_name": "block_identity_ring_fraud_combo",
    "description": "Block transactions that exhibit both identity fraud and ring fraud characteristics.",
    "proposed_change": {
      "condition": "transaction.has_fraud_tag('identity_fraud') and transaction.has_fraud_tag('ring_fraud')",
      "verdict": "block",
      "rationale": "Blocking transactions with both identity and ring fraud tags will prevent complex fraud schemes."
    },
    "expected_impact": "This rule will block transactions that are part of sophisticated fraud schemes involving identity and ring fraud.",
