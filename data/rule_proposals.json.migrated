[
  {
    "proposal_id": "ac4d7ddd-9ac1-4cb6-bf7e-7672ca87a897",
    "pattern_tags": [
      "new_account"
    ],
    "pattern_count": 4,
    "pattern_finding_type": "novel_pattern",
    "rule_type": "hard_rule",
    "rule_name": "block_new_account_pattern",
    "description": "Block transactions from new accounts exhibiting suspicious patterns.",
    "proposed_change": {
      "condition": "transaction.account_age < 30 and transaction.suspicious_pattern_detected",
      "verdict": "block",
      "rationale": "New accounts with suspicious patterns have a high likelihood of being fraudulent."
    },
    "expected_impact": "This rule will block potentially fraudulent transactions from new accounts, reducing fraud risk.",
    "risk": "There is a risk of blocking legitimate transactions from new accounts, but the likelihood is low given the pattern's confidence level.",
    "status": "pending",
    "created_at": "2026-03-20T23:49:55.321053+00:00"
  },
